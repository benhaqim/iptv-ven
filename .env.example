# ============================================================
# Supabase
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Project Settings → API → service_role key (server-only, never ship to browser)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ============================================================
# Encryption key for sensitive settings stored in DB (SMTP password).
# Generate with: openssl rand -base64 32
SETTINGS_ENC_KEY=replace-me-with-32-bytes-base64

# Public-site URL (used in email links). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
